<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Review</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
</head>

<style>
    body {
        background-image: url("/img/bg2.png");
        background-attachment: fixed;
        background-size: cover;
        color: white;
        margin: 0;
        padding: 40px 0;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
    }

    form {
        width: 60%;
        max-width: 700px;
        margin: 0 auto;
        background: rgba(10, 10, 10, 0.75);
        padding: 30px;
        border-radius: 16px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-size: 20px;
    }

    input, textarea, select {
        width: 100%;
        padding: 12px;
        margin-bottom: 24px;
        border-radius: 10px;
        border: none;
        box-sizing: border-box;
        font-size: 18px;
    }

    textarea {
        min-height: 120px;
        resize: vertical;
    }

    button {
        padding: 12px 24px;
        background-color: #4CAF50;
        border: none;
        color: white;
        border-radius: 10px;
        cursor: pointer;
        font-size: 18px;
    }

    button:hover {
        background-color: #45a049;
    }
</style>

<body>
    <%- include("common/header") %>
    <h1>Edit Your Review</h1>
    <!-- Display error message if validation failed -->
    <% if (result === "fail") { %>
        <div style="color: red;">
            <%= msg %> <!-- Display the error message here -->
        </div>
    <% } %>
        <!-- Form to edit the review -->
    <form action="/update-review/<%= review._id %>" method="POST">
        <!-- Pet Name -->
        <label for="petName">Pet Name:</label>
        <input type="text" name="petName" value="<%= review.petName %>" required>

        <!-- Title -->
        <label for="title">Review Title:</label>
        <input type="text" name="title" value="<%= review.title %>" required>

        <!-- Rating -->
        <label for="rating">Rating:</label><br>
        <select name="rating" required>
            <option value="">Please Insert a Rating</option>
            <option value="1" <%= review.rating == 1 ? "selected" : "" %>>1</option>
            <option value="2" <%= review.rating == 2 ? "selected" : "" %>>2</option>
            <option value="3" <%= review.rating == 3 ? "selected" : "" %>>3</option>
            <option value="4" <%= review.rating == 4 ? "selected" : "" %>>4</option>
            <option value="5" <%= review.rating == 5 ? "selected" : "" %>>5</option>
        </select>
        <br><br>

        <!-- Message -->
        <label for="message">Review Message:</label>
        <textarea name="message" required><%= review.message %></textarea>

        <!-- Submit Button -->
        <button type="submit">Update Review</button>
    </form>
</body>
</html>