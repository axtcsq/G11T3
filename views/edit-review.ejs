<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Review</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: #fff;
            padding: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin: 40px auto;
        }

        h3 {
            text-align: center;
            margin-bottom: 20px;
            font-weight: 600;
        }

        label {
            font-size: 0.85rem;
            opacity: 0.85;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            color: white;
            outline: none;
        }

        textarea {
            resize: none;
        }

        button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .msg {
            text-align: center;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .error {
            color: #ff6b6b;
        }
    </style>
</head>

<body>
    <%- include("common/header") %>

    <div class="card">
        <h3>Edit Your Review</h3>

        <!-- Display error message -->
        <% if (result === "fail") { %>
            <p class="msg error"><%= msg %></p>
        <% } %>

        <form action="/update-review/<%= review._id %>" method="POST">
            <!-- Pet Name -->
            <label>Pet Name</label>
            <input type="text" name="petName" value="<%= review.petName %>" required>

            <!-- Title -->
            <label>Review Title</label>
            <input type="text" name="title" value="<%= review.title %>" required>

            <!-- Rating -->
            <label>Rating</label>
            <select name="rating" required>
                <option value="">Please Insert a Rating</option>
                <option value="1" <%= review.rating == 1 ? "selected" : "" %>>1</option>
                <option value="2" <%= review.rating == 2 ? "selected" : "" %>>2</option>
                <option value="3" <%= review.rating == 3 ? "selected" : "" %>>3</option>
                <option value="4" <%= review.rating == 4 ? "selected" : "" %>>4</option>
                <option value="5" <%= review.rating == 5 ? "selected" : "" %>>5</option>
            </select>

            <!-- Message -->
            <label>Review Message</label>
            <textarea name="message" rows="4" required><%= review.message %></textarea>

            <button type="submit">Update Review</button>
        </form>
    </div>
</body>
</html>