<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adoption History</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- CSS to beautify page -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        h3 {
            margin: 20px 0 10px;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            backdrop-filter: blur(10px);
            border-radius: 12px;
            overflow: hidden;
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
        }

        th {
            background: rgba(255, 183, 0, 0.15);
            font-weight: 500;
        }

        tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        tr:hover {
            background: rgba(255,255,255,0.05);
        }
    </style>
</head>

<body>

    <%- include("common/header") %>

    <h3>Application History</h3>
  
    <table border="1">
        <tr>
            <th>Name</th>
            <th>Pet ID</th>
            <th>Application Time</th>
            <th>Status</th>
        </tr>

        <% adoptedList.forEach(adopted => { %>
            <tr>
                <td><%= adopted.userName %></td>
                <td><%= adopted.petId %></td>
                <td><%= (adopted.adoptedAt).toLocaleString() %></td>
                <td><%= adopted.status %></td>
            </tr>
        <% }) %>
        
    </table>
    
</body></html>