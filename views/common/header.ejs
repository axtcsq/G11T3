<!-- Nav Bar -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Pet</title>
  
  <style>
      /* Unvisited link */
      a:link {
          color: white;
      }

      /* Visited link */
      a:visited {
          color: goldenrod;
      }

      /* Mouse over link */
      a:hover {
          color: cyan;
      }
      /* Dropdown container */
      .dropdown {
          display: inline-block;
          position: relative;
      }

      /* Button */
      .dropbtn {
          cursor: pointer;
          color: white;
      }

      /* Dropdown menu */
      .dropdown-content {
          display: none;
          position: absolute;
          background-color: #333;
          min-width: 150px;
          z-index: 1;
      }

      /* Links inside dropdown */
      .dropdown-content a {
          display: block;
          padding: 8px 12px;
          text-decoration: none;
          color: white;
      }

      /* Hover effect */
      .dropdown-content a:hover {
          background-color: #555;
      }

      /* Show dropdown on hover */
      .dropdown:hover .dropdown-content {
          display: block;
      }
      /* Force navbar to always align left and span full width */
      body {
          width: 100%;
      }

      nav {
          width: 100%;
          display: flex;
          justify-content: flex-start; /* force left alignment */
          align-items: center;
          gap: 10px;
      }

      /* Prevent parent flex containers from centering navbar */
      nav {
          align-self: stretch;
      }

      .logout-btn {
          padding: 6px 12px;
          border-radius: 20px;
          background: rgba(255, 183, 77, 0.2);
          border: 1px solid rgba(255, 183, 77, 0.6);
          color: #ffcc80;
          text-decoration: none;
          transition: all 0.2s ease;
      }

      .logout-btn:hover {
          background: rgba(255, 183, 77, 0.35);
          color: #fff;
      }
  </style>
</head>

<body>
  <nav>
    <!-- Dynamically updates to login/logout -->
    <% if (user) { %>
      <a href="/logout" class="logout-btn">Logout</a> |
    <% } else { %>
      <a href="/login">Login</a> |
    <% } %>

    <!-- Dropdown Menu -->
    <!-- Pet Records -->
    <div class="dropdown">
      <span class="dropbtn">Pet Records ▾</span>
      <div class="dropdown-content">
        <a href="/display-pet">View Pets</a>
        <!-- ADMIN ONLY -->
        <% if (user && user.type === "admin") { %>
          <a href="/add-pet">Add Pet</a>
          <a href="/edit-pet">Update Pet</a>
          <a href="/del-pet">Delete Pet</a>
        <% } %>
      </div>
    </div> |

    <!-- User Records - ADMIN ONLY -->
    <% if (user && user.type === "admin") { %>
      <div class="dropdown">
        <span class="dropbtn">User Records ▾</span>
        <div class="dropdown-content">
          <a href="/display-user">View Users</a>
          <a href="/add-user">Add User</a>
          <a href="/edit-user">Update User</a>
          <a href="/del-user">Delete User</a>
        </div>
      </div> |
    <% } %>

    <!-- Adoption Records - ADMIN ONLY -->
    <% if (user && user.type === "admin") { %>
      <div class="dropdown">
        <span class="dropbtn">Adoption Records ▾</span>
        <div class="dropdown-content">
          <a href="/adopted-list">View Adopted</a>
          <a href="/edit-adopted">Edit Adopted</a>
          <a href="/del-adopted">Delete Adopted</a>
        </div>
      </div> |
    <% } %>

    <!-- Favourites -->
    <div class="dropdown">
      <span class="dropbtn">Favourites ▾</span>
      <div class="dropdown-content">
        <a href="/view-favourites">View Favourites</a>
      </div>
    </div> |

    <!-- Appointments --> <!-- work in progess -->
    <div class="dropdown">
      <span class="dropbtn">Appointments ▾</span>
      <div class="dropdown-content">
        <a href="/view-appointment">View My Appointments</a>
      </div>
    </div> |
    
      <!-- Review Records -->
    <div class="dropdown">
      <span class="dropbtn">Reviews ▾</span>
      <div class="dropdown-content">
        <a href="/pet-reviews">View Reviews</a>
        <a href="/add-review">Add Review</a>
        <a href="/my-reviews">Update My Reviews</a>
    </div>
  </div>
</nav>

</body>
</html>