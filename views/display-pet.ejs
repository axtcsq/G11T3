<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pet Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
</head>

<style>
    body {
        background-image: url("./img/bg2.png");
        background-attachment: fixed;  
        background-size: cover;
        color: white;
    }
    table {
        border-collapse: collapse;
    }
    th, td {
        padding: 10px 15px;
        text-align: left;
    }
</style>

<body>

  <%- include("common/header") %>

  <!-- EJS conditional block: Check if there are any pet list -->
  <% if (petList.length === 0) { %>
    <p>No pets yet.</p> <!-- Message when there is no pets -->
    
  <% } else { %>
    
    <h2>Pet Records</h2>

    <form action="/adopted-pets" method="post">
      <p>Thank you for considering to adopt our pets. Here are the pets that are adoptable currently <mark>(you can only choose one):</mark>:</p>

      <table border="1">
          <tr>
            <th>No.</th>  
            <th>Breed</th>
            <th>Name</th>
            <th>Age (years)</th>
            <th>Description</th>
            <th>Adopt?</th>
          </tr>

          <% let i = 1; %>
          <% let dogCount = 0; %>
          <% let catCount = 0; %>

          <!-- EJS loop to render each pet -->
          <% petList.forEach(pet => { %>
        
            <tr>
              <td><%= i %>.</td>
              <td><%= pet.type %></td><!-- Display the pet type -->
              <td><%= pet.name %></td><!-- Display the pet name -->
              <td><%= pet.age %></td><!-- Display the pet age -->
              <td><%= pet.desc %></td><!-- Display the pet description -->
              <td>
                <!-- Smth smth add validation only can choose 1 pet to adopt & retain selection value -->
                <input type="radio" name="selectPet" value="<%= pet.name %>">
              </td>
            </tr>

            <!-- Counter for dog, cat & no. -->
            <% if (pet.type.toLowerCase() === "dog") { dogCount++; } %>
            <% if (pet.type.toLowerCase() === "cat") { catCount++; } %>
            <% i++; %>

          <% }); %>
      </table>

      <br>
      <button>Adopt!</button>

    </form>

    <br>

    <h2>Summary</h2>
    <table border="1">
      <tr>
        <th>Total Pets</th>
        <td><%= i - 1 %></td>
      </tr>

      <tr>
        <th>Total Dogs</th>
        <td><%= dogCount %></td>
      </tr>

      <tr>
        <th>Total Cats</th>
        <td><%= catCount %></td>
      </tr>
    </table>
    
  <% } %>
     
</body>
</html>