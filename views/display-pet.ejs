<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pet Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- CSS to beautify page -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        h2 {
            margin: 20px 0 10px;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            overflow: hidden;
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
        }

        th {
            background: rgba(255, 183, 0, 0.15);
            font-weight: 500;
        }

        tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        tr:hover {
            background: rgba(255,255,255,0.05);
        }

        button {
            margin-top: 10px;
            padding: 10px 14px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .highlight {
            background: rgba(255, 183, 77, 0.35);
            font-weight: 600;
        }

        hr {
            margin: 20px 0;
            border: none;
            height: 1px;
            background: rgba(255,255,255,0.2);
        }
    </style>
</head>

<body>

  <%- include("common/header", {isAdmin: isAdmin}) %>

  <% if (typeof error !== 'undefined') { %>
    <p style="color: red;"><%= error %></p>
  <% } %>
  
  <!-- EJS conditional block: Check if there are any pet list -->
  <% if (petList.length === 0) { %>
    <p>No pets yet.</p> <!-- Message when there is no pets -->
    
  <% } else { %>
    
    <h2>Pet Records</h2>

    <form action="/adopted-pets" method="post">
      <p>Hey <%= userName %>! Thank you for considering to adopt our pets. Here are the pets that are adoptable currently <mark>(you can only choose one)</mark>:</p>

      <br>

      <table border="1">
          <tr>
            <th>No.</th>  
            <th>Record ID</th>
            <th>Breed</th>
            <th>Name</th>
            <th>Age (years)</th>
            <th>Description</th>
            <th>Photo</th>
            <th>Favourites</th>
            <th>Adopt?</th>
          </tr>

          <!-- For counter -->
          <% let i = 1; %>
          <% let dogCount = 0; %>
          <% let catCount = 0; %>

          <!-- EJS loop to render each pet -->
          <% petList.forEach(pet => { %>
        
            <tr>
              <td><%= i %>.</td>
              <td><%= pet.id %></td>
              <td><%= pet.type %></td>
              <td><%= pet.name %></td>
              <td><%= pet.age %></td>
              <td><%= pet.desc %></td>
              <td><img src ="/pet-img/<%=pet.photo %>" width="100"> </td>
              <td>
                <% if (favouriteList.includes(pet.id)) { %>
                  <a href="/remove-favourite?petID=<%=pet.id%>">❤️ Remove</a>
                <% } else { %>
                  <a href="/add-favourite?petID=<%=pet.id%>">🤍 Add</a>
                <% } %>
              </td>
              <td>
                <!-- Smth smth add validation only can choose 1 pet to adopt & retain selection value -->
                <input type="radio" name="selectPet" value="<%= pet.id %>">
              </td>
            </tr>

            <!-- Counter for dog, cat & no. -->
            <% if (pet.type.toLowerCase() === "dog") { dogCount++; } %>
            <% if (pet.type.toLowerCase() === "cat") { catCount++; } %>
            <% i++; %>

          <% }); %>
      </table>
      <input type="hidden" name="admin" value="<% isAdmin %>">
      
      
      <br>
      <button>Adopt!</button>

    </form>

    <br>
    <hr>

    <h2>Summary</h2>
    <table border="1">
      <tr>
        <th>Total Type</th>
        <th>Count</th>
      </tr>

      <tr>
        <th>Dogs</th>
        <td><%= dogCount %></td>
      </tr>

      <tr>
        <th>Cats</th>
        <td><%= catCount %></td>
      </tr>

      <tr class="highlight">
        <th>Pets</th>
        <td><%= i - 1 %></td>
      </tr>
    </table>
    
  <% } %>
     
</body>
</html>