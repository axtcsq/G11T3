<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pet Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        h2 {
            margin: 20px 0 10px;
            font-weight: 600;
        }

        /* Table styles kept for the Summary section at the bottom */
        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            overflow: hidden;
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
        }

        th {
            background: rgba(255, 183, 0, 0.15);
            font-weight: 500;
        }

        tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .warning {
            color: #ffee00;
            font-weight: 600;
        }

        button {
            padding: 10px 14px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .highlight {
            background: rgba(255, 183, 77, 0.35);
            font-weight: 600;
        }

        hr {
            margin: 20px 0;
            border: none;
            height: 1px;
            background: rgba(255,255,255,0.2);
        }

        /* --- NEW GRID & CARD STYLES --- */
        .pet-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr); /* 2 cards per row */
            gap: 25px;
            margin-top: 20px;
        }

        .pet-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease;
        }

        .pet-card:hover {
            background: rgba(255,255,255,0.12);
        }

        .pet-photo {
            width: 100%;
            height: 250px; /* Keeps images uniform */
            object-fit: cover;
        }

        .pet-info {
            padding: 28px;
            display: flex;
            flex-direction: column;
            flex-grow: 1; /* Pushes the buttons to the bottom evenly */
        }

        .pet-info h3 {
            margin-bottom: 12px;
            color: #ffb74d;
            font-size: 1.4rem;
        }

        .pet-details {
            margin-bottom: 10px;
            font-size: 0.95rem;
            color: #e0e0e0;
        }

        .pet-desc {
            margin-top: 10px;
            margin-bottom: 20px;
            font-style: italic;
            color: #ccc;
            line-height: 1.4;
        }

        .pet-actions {
            margin-top: auto; /* Aligns buttons to the bottom of the card */
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 15px;
        }

        .fav-link {
            text-decoration: none;
            color: white;
            background: rgba(0, 0, 0, 0.3);
            padding: 8px 12px;
            border-radius: 8px;
            transition: background 0.2s;
            font-size: 0.9rem;
        }

        .fav-link:hover {
            background: rgba(0, 0, 0, 0.5);
        }

        .view-details-link {
            text-decoration: none;
            color: white;
            background: linear-gradient(135deg, #42a5f5, #64b5f6);
            padding: 8px 14px;
            border-radius: 999px; /* pill shape */
            font-size: 0.9rem;
            font-weight: 500;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
            display: inline-block;
        }

        .view-details-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(66,165,245,0.4);
            background: linear-gradient(135deg, #1e88e5, #42a5f5);
        }
    </style>
</head>

<body>

  <%- include("common/header", {isAdmin: isAdmin}) %>
  
  <% if (petList.length === 0) { %>
    <br>
    <p>No pets yet.</p> 
    <br>
    <form action="/display-pet" method="get" style="margin-top: 10px;">
    <button type="submit" style="padding: 7px 12px; border-radius: 7px; background-color: #ff9800; color: white; border: none;">
      Return to View Pets
    </button>
  </form>
    
  <% } else { %>
    <br>
  <!-- this gives the get response, filterType, and pets controller will then filter the type using the filtertype -->
  <form action="/display-pet" method="get" style="margin-bottom: 20px; background: rgba(255,255,255,0.1); padding: 15px; border-radius: 10px;">
    <label>Filter by animal: </label>
    <select name="filterType" style="padding: 5px; border-radius: 7px;">
      <option value="all" <%= filterType === "all" ? " selected" : "" %>>All Pets</option>
      <option value="dog" <%= filterType === "dog" ? " selected" : "" %>>Dogs</option>
      <option value="cat" <%= filterType === "cat" ? " selected" : "" %>>Cats</option>
      <option value="rabbit" <%= filterType === "rabbit" ? " selected" : "" %>>Rabbits</option>
    </select>
    <button type="submit" style="margin-top: 0; padding: 7px 12px;">Apply</button>
  </form>
  
    
    <h2>Pet Records</h2>

    <form action="/application-pets" method="post">
      <p>Hey <%= userName %>! Thank you for considering to adopt our pets. Here are the pets that are adoptable currently <strong class="warning">[ you can only select one ]</strong>:</p>

      <br>

        <% if (error) { %>
          <p style="color: red;"><%= error %></p>
        <% } %>

      <div class="pet-grid">
          <% let i = 1; %>
          <% let dogCount = 0; %>
          <% let catCount = 0; %>

          <% petList.forEach(pet => { %>
            
            <div class="pet-card">
              <img src="/uploads/<%= pet.photo %>" alt="<%= pet.name %>" class="pet-photo">
              
              <div class="pet-info">
                <h3><%= i %>. <%= pet.name %></h3>
                <div class="pet-details">
                  <strong>Pet No:</strong> <%= pet.id %> | 
                  <strong>Breed:</strong> <%= pet.breed %> | 
                  <strong>Age:</strong> <%= pet.age %> years
                </div>
                
                <p class="pet-desc">"<%= pet.desc %>"</p>
                
                <div class="pet-actions">
                  <% if (favouriteList.includes(pet.id)) { %>
                    <a href="/remove-favourite?petID=<%=pet.id%>" class="fav-link">❤️ Remove</a>
                  <% } else { %>
                    <a href="/add-favourite?petID=<%=pet.id%>" class="fav-link">🤍 Add Fav</a>
                  <% } %>
                    <a href="/display-pets/<%= pet.name %>" class="view-details-link">🔎 View More Details</a>
                  <button type="submit" name="selectPet" value="<%= pet.id %>">
                      Meet Me!
                  </button>
                </div>
              </div>
            </div>

            <% if (pet.type.toLowerCase() === "dog") { dogCount++; } %>
            <% if (pet.type.toLowerCase() === "cat") { catCount++; } %>
            <% i++; %>

          <% }); %>
      </div>

      <input type="hidden" name="admin" value="<%= isAdmin %>">
      <input type="hidden" name="source" value="pets">
      <input type="hidden" name="userName" value="<%= userName %>">

    </form>

    <br>
    <hr>
  
  <% let summary = {};

    if (filterType === "all") {
      petList.forEach(pet => {
        const type = pet.type.substring(0, 1).toUpperCase() + pet.type.substring(1).toLowerCase();
        summary[type] = (summary[type] || 0) + 1;
      });
    } else {
      petList.forEach(pet => {
        const breed = pet.breed || pet.type;
        summary[breed] = (summary[breed] || 0) + 1;
      });
    }
    %>

<h2>Summary</h2>
<table border="1">
  <tr>
    <th><%= filterType === "all" ? "Type" : "Breed" %></th>
    <th>Count</th>
  </tr>

  <% for (let key in summary) { %>
    <tr>
      <td><%= key %></td>
      <td><%= summary[key] %></td>
    </tr>
  <% } %>

  <tr class="highlight">
    <td>Total Pets</td>
    <td><%= petList.length %></td>
  </tr>
</table>
<% } %>

</body>
</html>