<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- CSS to beautify page -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        h2 {
            margin: 20px 0 10px;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            overflow: hidden;
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
        }

        th {
            background: rgba(255, 183, 0, 0.15);
            font-weight: 500;
        }

        tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        tr:hover {
            background: rgba(255,255,255,0.05);
        }

        .highlight {
            background: rgba(255, 183, 77, 0.35);
            font-weight: 600;
        }

        hr {
            margin: 20px 0;
            border: none;
            height: 1px;
            background: rgba(255,255,255,0.2);
        }
    </style>
</head>

<body>

  <%- include("common/header") %>

  <!-- EJS conditional block: Check if there are any user list -->
  <% if (userList.length === 0) { %>
    <p>No users yet.</p> <!-- Message when there is no users -->
    
  <% } else { %>
    
    <h2>User Records</h2>

    <table border="1">
        <tr>
          <th>No.</th>  
          <th>User ID</th>
          <th>Name</th>
          <th>Gender</th>
          <th>Type</th>
        </tr>

        <!-- For counter -->
        <% let i = 1; %>
        <% let adminCount = 0; %>
        <% let userCount = 0; %>

        <!-- EJS loop to render each pet -->
        <% userList.forEach(user => { %>
      
          <tr>
            <td><%= i %>.</td>
            <td><%= user.userName %></td>
            <td><%= user.fullName %></td>
            <td><%= user.gender %></td>
            <td><%= user.type %></td>
          </tr>

          <!-- Counter for adm, cat & no. -->
          <% if (user.type.toLowerCase() === "admin") { adminCount++; } %>
          <% if (user.type.toLowerCase() === "user") { userCount++; } %>
          <% i++; %>

        <% }); %>
    </table>

    <br>
    <hr>

    <h2>Summary</h2>
    <table border="1">
      <tr>
        <th>Type</th>
        <th>Count</th>
      </tr>

      <tr>
        <td>Admins</td>
        <td><%= adminCount %></td>
      </tr>

      <tr>
        <td>Users</td>
        <td><%= userCount %></td>
      </tr>

      <tr class="highlight">
        <td>Total</td>
        <td><%= i - 1 %></td>
      </tr>
    </table>
    
  <% } %>
     
</body>
</html>