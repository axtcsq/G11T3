<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Appointment</title>
    <link rel="icon" type="image/x-icon" href="/img/paw.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        /* Shared Styles from application-pets.ejs */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("/img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }
        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 800px; /* Wider to accommodate the grid */
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin: 40px auto;
        }
        h3 { margin-bottom: 20px; color: #ffb74d; }

        /* Grid Styling from application-pets.ejs */
        .appointment-grid { display: flex; gap: 15px; overflow-x: auto; padding: 10px 0; margin-bottom: 20px; }
        .day-column {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            min-width: 180px;
            padding: 15px;
            text-align: center;
        }
        .time-slot-label {
            display: block;
            padding: 10px;
            border: 1px solid #ffb74d;
            border-radius: 6px;
            color: #ffb74d;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.2s;
        }
        .time-slot-radio { display: none; }
        .time-slot-radio:checked + .time-slot-label { background: #ffb74d; color: #1a2a5a; }
        
        button {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 700;
            cursor: pointer;
        }
    </style>
</head>
    <body>
        <%- include("common/header", {isAdmin: isAdmin}) %>

        <div class="card">
            <h3>Reschedule Appointment</h3>
            <p style="margin-bottom: 20px; font-size: 0.9rem;">Current Slot: <strong><%= appointment.date %></strong> at <strong><%= appointment.time %></strong></p>

            <form action="/update-appointment/<%= appointment._id %>" method="POST">
                <div class="appointment-grid">
                    <% 
                    const dayOptions = { weekday: 'long' };
                    const dateOptions = { month: 'short', day: 'numeric' };
                    
                    for(let i = 1; i <= 7; i++) { 
                        let d = new Date();
                        d.setDate(d.getDate() + i);
                        let dateVal = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
                    %>
                        <div class="day-column">
                            <div class="day-header">
                                <div style="font-weight: 600;"><%= d.toLocaleDateString(undefined, dayOptions) %></div>
                                <div style="font-size: 0.8rem; color: #ccc;"><%= d.toLocaleDateString(undefined, dateOptions) %></div>
                            </div>

                            <div class="time-options">
                                <% const slots = ["10:00 AM - 12:00 PM", "12:00 PM - 2:00 PM", "2:00 PM - 4:00 PM", "4:00 PM - 6:00 PM"]; %>
                                <% slots.forEach(slot => { %>
                                    <% 
                                        // 1. Check if this slot is taken by ANYONE in the database
                                        const isBooked = bookedSlots.some(b => b.date === dateVal && b.time === slot);
                                        
                                        // 2. Check if this is the specific slot the user is ALREADY booked for
                                        // We must allow them to see/re-select their current slot!
                                        const isCurrentSlot = appointment.date === dateVal && appointment.time === slot;
                                    %>
                                    <div>
                                        <% if (isBooked && !isCurrentSlot) { %>
                                            <label class="time-slot-label" style="background: #333; color: #666; border-color: #444; cursor: not-allowed; opacity: 0.6;">
                                                <%= slot %> (Taken)
                                            </label>
                                        <% } else { %>
                                            <input type="radio" 
                                                name="appointmentDateTime" 
                                                value="<%= dateVal %>|<%= slot %>" 
                                                id="<%= dateVal %>-<%= slot %>" 
                                                class="time-slot-radio" 
                                                <%= isCurrentSlot ? 'checked' : '' %> 
                                                required>
                                            <label for="<%= dateVal %>-<%= slot %>" class="time-slot-label">
                                                <%= slot %>
                                            </label>
                                        <% } %>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <button type="submit">Update Appointment</button>
                <a href="/view-appointment" style="display: block; text-align: center; color: #ccc; margin-top: 15px; text-decoration: none; font-size: 0.85rem;">Cancel</a>
            </form>
        </div>
    </body>