<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Appointment</title>
    <link rel="icon" type="image/x-icon" href="/img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("/img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin: 40px auto;
            text-align: center;
        }

        h2 {
            margin-bottom: 20px;
            font-weight: 600;
        }

        label {
            display: block;
            text-align: left;
            font-size: 0.85rem;
            opacity: 0.85;
            margin-top: 10px;
        }

        select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            color: white;
            outline: none;
        }

        button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        select {
        background: rgba(255,255,255,0.15);
        color: white;
        }

        select option {
        background: #222;  
        color: white;       
        }
    </style>
</head>

<body>
    <%- include("common/header", {isAdmin: false}) %>

    <div class="card">
        <h2>Reschedule Appointment for <%= appointment.name %></h2>

        <form action="/update-appointment/<%= appointment._id %>" method="POST">
            
            <label>Pick a New Date</label>
            <select name="appointmentDate" id = "appointmentDate">
               <% 
                const options = { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' };
                for(let i = 1; i <= 7; i++) {
                    let d = new Date();
                    d.setDate(d.getDate() + i);
                    
                    // Force the date to stay in local format YYYY-MM-DD
                    let year = d.getFullYear();
                    let month = String(d.getMonth() + 1).padStart(2, '0');
                    let day = String(d.getDate()).padStart(2, '0');
                    let dateStr = `${year}-${month}-${day}`;
                %>
                    <option value="<%= dateStr %>" <%= appointment.date === dateStr ? 'selected' : '' %>>
                        <%= d.toLocaleDateString(undefined, options) %>
                    </option>
                <% } %>
            </select>
            
            <label>Select Time Slot</label>
            <select name="timeSlot" required>
                <option value="10:00 AM -12:00 PM"<%= appointment.time === "10:00 AM -12:00 PM" ? 'selected' : '' %>>10:00 AM - 12:00 PM</option>
                <option value="12:00 PM -2:00 PM" <%= appointment.time === "12:00 PM -2:00 PM" ? 'selected' : '' %>>12:00 PM - 2:00 PM</option>
                <option value="2:00 PM - 4:00 PM"<%= appointment.time === "2:00 PM - 4:00 PM" ? 'selected' : '' %>>2:00 PM - 4:00 PM</option>
                <option value="4:00 PM - 6:00 PM" <%= appointment.time === "4:00 PM - 6:00 PM"? 'selected' : '' %>>4:00 PM - 6:00 PM</option>
            </select>
            
            <button type="submit">Confirm Reschedule</button>
        </form>
    </div>
</body>
</html>