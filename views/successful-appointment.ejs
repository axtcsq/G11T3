<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Appointment Successful</title>
    <link rel="icon" type="image/x-icon" href="/img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("/img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 40px 25px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin: 60px auto;
            text-align: center;
        }

        img {
            max-width: 220px;
            margin-bottom: 20px;
        }

        h1 {
            color: #90ee90;
            font-size: 2.2rem;
            margin-bottom: 10px;
        }

        p {
            font-size: 1rem;
            opacity: 0.9;
            margin-bottom: 20px;
        }

        .btn {
            display: inline-block;
            padding: 10px 18px;
            border-radius: 20px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white !important;
            text-decoration: none;
            font-weight: 600;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            margin: 5px;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .link {
            display: block;
            margin-top: 10px;
            font-size: 0.9rem;
            color: #bbb;
            text-decoration: none;
        }

        .link:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>
    <%- include("common/header", {isAdmin: false}) %>

    <div class="card">
        <img src="/img/happy-animals.png" alt="Happy pets">

        <h1>Success! 🐾</h1>

        <p>Your appointment has been booked successfully. We can't wait to see you!</p>

        <a href="/view-appointment" class="btn">View My Appointments</a>

        <a href="/" class="link">Return to Home</a>
    </div>
</body>
</html>