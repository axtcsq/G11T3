<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Pet Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
</head>

<style>
    body {
        background-image: url("./img/bg2.png");
        background-attachment: fixed;  
        background-size: cover;
        color: white;
    }
    table {
        border-collapse: collapse;
    }
    th, td {
        padding: 10px 15px;
        text-align: left;
    }
</style>

<body>
    <%- include("common/header") %>

    <% if (result) { %>
    <h3>Update Pet Records for <%= result.name %>:</h3>

    <form action="/update-pet" method="POST">
        <table border="1">
            <tr>
                <th>Name :</th>
                <td><input type="text" name="name" value="<%= result.name %>"></td>
            </tr>
            <tr>
                <th>Type:</th>
                <td><input type="text" name="type" value="<%= result.type %>"></td>
                </tr>
            <tr>
                <th>Age:</th><td><input type="text" name="age" value = "<%= result.age %>"></td>
            </tr>
            <tr>
                <th>Desc:</th><td><input type="text" name="desc" value="<%= result.desc %>"></td>
            </tr>
            <input type="hidden" name="id" value="<%= result.id %>">
            <tr>
                <td colspan="2"><button type="submit">Update Pet!</button></td>
            </tr>
        </table>      
    </form>
     <% } %>

    <% if (successful) { %>
        <p style="color: lightgreen;">Pet updated successfully!</p>
    <% } %>

<br><br>

</body>
</html>