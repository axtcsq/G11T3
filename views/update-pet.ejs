<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Pet Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- CSS to beautify page -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-image: url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: #fff;
            padding: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin-top: 20px;
        }

        h3 {
            text-align: center;
            margin-bottom: 20px;
            font-weight: 600;
        }

        label {
            font-size: 0.85rem;
            opacity: 0.85;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            color: white;
            outline: none;
        }

        .radio-group {
            display: flex;
            gap: 15px;
            margin-top: 5px;
            margin-bottom: 15px;
            font-size: 0.85rem;
        }

        .radio-group input {
            width: auto;
        }

        button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .msg {
            text-align: center;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .success {
            color: #90ee90;
        }
    </style>
</head>

<body>
    <%- include("common/header") %>

    <% if (successful) { %>
        <p class="msg success">Pet updated successfully!</p>
    <% } %>

    <% if (result) { %>
    <div class="card">
        <h3>Update Pet: <%= result.name %></h3>

        <form action="/update-pet" method="POST">
            <!-- Name -->
            <label>Name</label>
            <input type="text" name="name" value="<%= result.name %>">

            <!-- Type -->
            <label>Type</label>
            <input type="text" name="type" value="<%= result.type %>">

            <!-- Age -->
            <label>Age</label>
            <input type="text" name="age" value="<%= result.age %>">

            <!-- Description -->
            <label>Description</label>
            <input type="text" name="desc" value="<%= result.desc %>">

            <!-- Hidden ID -->
            <input type="hidden" name="id" value="<%= result.id %>">

            <!-- Photo -->
            <label>Photo</label>
            <input type="text" name="photo" value="<%= result.photo %>">

            <button type="submit">Update Pet</button>
        </form>
    </div>
    <% } %>

</body>
</html>