<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up</title>
</head>
<body>
    <% if (!userName || errors.length > 0) { %>
        <!-- Not submitted or got errors. Display them. -->
        <ul style="color: red">
            <% errors.forEach(error => { %>
                <li><%= error %></li>
            <% }) %>
        </ul>

        <h1>Sign Up</h1>
        
        <form action="/signup" method="post">
            <!-- Username -->
            <label for="userName">Username:</label>
            <input type="text" name="userName" value="<%= userName %>" required>

            <br><br>
            
            <!-- Full Name -->
            <label for="fullName">Full Name:</label>
            <input type="text" name="fullName" value="<%= fullName %>" required>

            <br><br>

            <!-- Password -->
            <label for="password">Password:</label>
            &nbsp;<input type="password" name="password" required>

            <br><br>

            <!-- Confirm Password -->
            <label for="password2">Confirm Password:</label>
            &nbsp;<input type="password" name="password2" required>

            <br><br>

            <button type="submit">Signup</button>

            <br><br>

            <em><p>If you're an existing user, <a href="/login"> login </a>here instead!</p></em>
        </form>
    <% } else { %>
        Welcome
        <%= fullName %>
        to Pet Adoption!
    <% } %>
</body>
</html>