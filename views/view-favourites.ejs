<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favourite Pets</title>
    <link rel="icon" type="image/x-icon" href="/img/paw.png">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("/img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        h2 {
            margin: 20px 0 10px;
            font-weight: 600;
        }

        .empty-msg {
            margin-top: 20px;
            font-size: 1rem;
        }

        .pet-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            margin-top: 20px;
        }

        .pet-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .pet-card:hover {
            background: rgba(255,255,255,0.12);
        }

        .pet-photo {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

        .pet-info {
            padding: 20px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .pet-info h3 {
            margin-bottom: 12px;
            color: #ffb74d;
            font-size: 1.4rem;
        }

        .pet-details {
            margin-bottom: 10px;
            font-size: 0.95rem;
            color: #e0e0e0;
        }

        .pet-desc {
            margin-top: 10px;
            margin-bottom: 12px;
            font-style: italic;
            color: #ccc;
            line-height: 1.4;
        }

        .fav-extra {
            margin-top: 8px;
            margin-bottom: 18px;
            line-height: 1.5;
            color: #f1f1f1;
        }

        .pet-actions {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 15px;
            flex-wrap: wrap;
        }

        .action-link {
            text-decoration: none;
            color: white;
            background: rgba(0, 0, 0, 0.3);
            padding: 8px 12px;
            border-radius: 8px;
            transition: background 0.2s;
            font-size: 0.9rem;
        }

        .action-link:hover {
            background: rgba(0, 0, 0, 0.5);
        }

        .edit-link {
            background: rgba(255, 183, 77, 0.25);
        }

        .edit-link:hover {
            background: rgba(255, 183, 77, 0.4);
        }

        .remove-link {
            background: rgba(255, 80, 80, 0.25);
        }

        .remove-link:hover {
            background: rgba(255, 80, 80, 0.45);
        }

        button {
            padding: 10px 14px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        @media (max-width: 900px) {
            .pet-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <%- include("common/header", {isAdmin: isAdmin}) %>

    <h2>Favourite Pets</h2>

    <% if (favouriteList.length === 0) { %>
        <form action="/view-favourites" method="get" style="margin-bottom: 20px; background: rgba(255,255,255,0.1); padding: 15px; border-radius: 10px;">
        <label>Filter by animal: </label>
          <select name="filterType" style="padding: 5px; border-radius: 7px;">
            <option value="all" <%= filterType === "all" ? "selected" : "" %>>All Pets</option>
            <option value="dog" <%= filterType === "dog" ? "selected" : "" %>>Dogs</option>
            <option value="cat" <%= filterType === "cat" ? "selected" : "" %>>Cats</option>
            <option value="rabbit" <%= filterType === "rabbit" ? "selected" : "" %>>Rabbits</option>
          </select>
          <button type="submit" style="margin-top: 0; padding: 7px 12px;">Apply</button>
        </form>
        <p class="empty-msg">No favourite pets yet.</p>
    <% } else { %>

        <% if (error) { %>
            <p style="color: red; margin-top: 10px;"><%= error %></p>
        <% } %>

        <form action="/view-favourites" method="get" style="margin-bottom: 20px; background: rgba(255,255,255,0.1); padding: 15px; border-radius: 10px;">
        <label>Filter by animal: </label>
          <select name="filterType" style="padding: 5px; border-radius: 7px;">
            <option value="all" <%= filterType === "all" ? "selected" : "" %>>All Pets</option>
            <option value="dog" <%= filterType === "dog" ? "selected" : "" %>>Dogs</option>
            <option value="cat" <%= filterType === "cat" ? "selected" : "" %>>Cats</option>
            <option value="rabbit" <%= filterType === "rabbit" ? "selected" : "" %>>Rabbits</option>
          </select>
          <button type="submit" style="margin-top: 0; padding: 7px 12px;">Apply</button>
        </form>

        <div class="pet-grid">
            <% let i = 1; %>
            <% favouriteList.forEach(favourite => { %>

                <div class="pet-card">
                    <img src="/uploads/<%= favourite.photo %>" alt="<%= favourite.name %>" class="pet-photo">

                    <div class="pet-info">
                        <h3><%= i %>. <%= favourite.name %></h3>

                        <div class="pet-details">
                            <strong>Pet No:</strong> <%= favourite.petID %> |
                            <strong>Gender:</strong> <%= favourite.gender %> |
                            <strong>Breed:</strong> <%= favourite.breed %> |
                            <strong>Colour:</strong> <%= favourite.colour %> |
                            <strong>Age:</strong> <%= favourite.age %> years old
                        </div>

                        <p class="pet-desc">"<%= favourite.desc %>"</p>

                        <div class="fav-extra">
                            <p><strong>Remark:</strong> <%= favourite.remark || "None" %></p>
                            <p><strong>Priority:</strong> <%= favourite.priority || "Not set" %></p>
                            <p><strong>Date Added:</strong> <%= new Date(favourite.dateAdded).toLocaleString() %></p>
                        </div>

                        <div class="pet-actions">
                            <a href="/edit-favourite?petID=<%= favourite.petID %>" class="action-link edit-link">Edit</a>

                            <a href="/delete-favourite?petID=<%= favourite.petID %>&source=favourites" class="action-link remove-link">Remove</a>

                            <form action="/application-pets" method="post" style="margin: 0;">
                                <input type="hidden" name="admin" value="<%= isAdmin %>">
                                <input type="hidden" name="source" value="favourites">
                                <input type="hidden" name="userName" value="<%= userName %>">

                                <button type="submit" name="selectPet" value="<%= favourite.petID %>">
                                    Meet Me!
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <% i++; %>
            <% }) %>
        </div>

    <% } %>

</body>
</html>