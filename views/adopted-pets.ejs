<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adopted Pet Summary</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin: 40px auto;
        }

        h3 {
            margin-bottom: 15px;
            font-weight: 600;
        }

        p {
            margin-bottom: 15px;
            opacity: 0.9;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            overflow: hidden;
            margin-top: 10px;
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
        }

        th {
            background: rgba(255,255,255,0.15);
            font-weight: 500;
        }

        tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .status {
            color: #90ee90;
            font-weight: 600;
        }

        label {
            font-size: 0.85rem;
            opacity: 0.85;
        }

        select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            color: white;
            outline: none;
        }

        button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .success-text {
            color: #90ee90;
        }

        select {
        background: rgba(255,255,255,0.15);
        color: white;
        }

        select option {
        background: #222;  
        color: white;       
        }
    </style>
</head>

<body>
    <%- include("common/header", {isAdmin: isAdmin}) %>
    
    <div class="card">
        <h3>Adopted Pet Summary</h3>
        
        <% if (pet) { %>
            <table>
                <thead>
                    <tr>
                        <th>Record ID</th>
                        <th>Adoption Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><%= pet.id %></td>
                        <td class="status">Pending ...</td>
                    </tr>
                </tbody>
            </table>

            <br>
            <p class="success-text">
                Congratulations <%= pet.userName %>! Your request to adopt pet record ID <%= pet.petId %> has been noted. We will keep in touch!
            </p>
            <div class="booking-section">
                <p>Congratulations! Your request for <%= pet.petName %> has been noted.</p>
                <a href="/book-appointment?petId=<%= pet.petId %>&petName=<%= pet.petName %>" class="btn-primary">
                    Schedule your Appointment
                </a>
            </div>
        <% } else { %>
            <p>No pet selection found. Please go back and select a pet.</p>
        <% } %>
    </div>
</body>
</html>