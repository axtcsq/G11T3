<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adopted Pet Summary</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
</head>

<style>
    body {
        background-image: url("./img/bg2.png");
        background-attachment: fixed;  
        background-size: cover;
        color: white;
    }
    table {
        border-collapse: collapse;
    }
    th, td {
        padding: 10px 15px;
        text-align: left;
    }
</style>

<body>
    <%- include("common/header", {isAdmin: isAdmin}) %>
    
    <h3>Adopted Pet Summary</h3>
    
    <% if (pet) { %>
        <table border="1" style="width: 80%; margin-top: 20px; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="background-color: rgba(255,255,255,0.1);">
                    <th>Record ID</th>
                    <th>Adoption Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><%= pet.id %></td>
                    <td style="color: #4CAF50; font-weight: bold;">Pending ...</td>
                </tr>
            </tbody>
        </table>
        
        <p style="margin-top: 20px; color: lightgreen;">
            Congratulations <%= pet.userName %>! Your request to adopt pet record ID <%= pet.petId %> has been noted. We will keep in touch!
        </p>

        <br>

        <h3>
            Please make an appointment below:
        </h3>
        <!-- added this chunk to display an appointment slot booker (Work in progress)-->
       <form action="/book" method="POST">
            <input type="hidden" name="petId" value="<%= pet.petId %>">
            <input type="hidden" name="userName" value="<%= pet.userName %>">
            
            <!-- date  -->
            <label for="appointmentDate">Pick a Date:</label><br>
            <select name="appointmentDate" id="appointmentDate" style="padding: 8px; margin-bottom: 10px; background-color: white; color: black;">
                <% 
                const options = { weekday: 'long', month: 'long', day: 'numeric' };
                for(let i = 1; i <= 7; i++) { 
                    let d = new Date();
                    d.setDate(d.getDate() + i);
                %>
                <option value="<%= d.toISOString().split('T')[0] %>">
                    <%= d.toLocaleDateString(undefined, options) %>
                </option>
                <% } %>
            </select>
            <br>

            <!-- Time -->
            <label for="timeSlot">Select Time Slot (2-hour intervals):</label><br>
            <select name="timeSlot" id="timeSlot" required style="padding: 8px; margin-bottom: 15px;">
                <option value="10:00-12:00">10:00 AM - 12:00 PM</option>
                <option value="12:00-14:00">12:00 PM - 02:00 PM</option>
                <option value="14:00-16:00">02:00 PM - 04:00 PM</option>
                <option value="16:00-18:00">04:00 PM - 06:00 PM</option>
            </select>
            
            <br>

            <button type="submit" style="background-color: #28a745; color: white; border: none; padding: 10px; cursor: pointer; border-radius: 4px;">
                Confirm Appointment
            </button>
    </form>
    <% } else { %>
        <p>No pet selection found. Please go back and select a pet.</p>
    <% } %></p>
</body>
</html>