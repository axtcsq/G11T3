<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adopted Pet Summary</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }
        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin: 40px auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            overflow: hidden;
            margin-top: 10px;
        }
        th, td { padding: 12px 14px; text-align: left; }
        th { background: rgba(255,255,255,0.15); font-weight: 500; }
        tr { border-bottom: 1px solid rgba(255,255,255,0.1); }
        .status { color: #90ee90; font-weight: 600; }
        
        /* Appointment Grid Styling */
        .appointment-grid { display: flex; gap: 15px; overflow-x: auto; padding: 10px 0; margin-bottom: 20px; }
        .day-column {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            min-width: 160px;
            padding: 15px;
            text-align: center;
        }
        .time-slot-label {
            display: block;
            padding: 10px;
            border: 1px solid #ffb74d;
            border-radius: 6px;
            color: #ffb74d;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
        }
        .time-slot-radio { display: none; }
        .time-slot-radio:checked + .time-slot-label { background: #ffb74d; color: #1a2a5a; }
        
        button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
        }
    </style>
</head>

<body>
    <%- include("common/header", {isAdmin: isAdmin}) %>
    
    <div class="card">
        <h3>Adopted Pet Summary</h3>
        
        <% if (pet) { %> <table>
                <thead>
                    <tr>
                        <th>Pet Number</th>
                        <th>Adoption Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><%= pet.id %></td>
                        <td class="status">Pending ...</td>
                    </tr>
                </tbody>
            </table>

            <br>
            <p class="success-text">
                Congratulations <%= userName %>! Your request to adopt pet (Pet Number  <%= pet.id %>) has been noted. We will keep in touch!
            </p>

            <h3>Please make an appointment below:</h3>

            <form action="/book" method="POST">
                <input type="hidden" name="petId" value="<%= pet.id %>">
                <input type="hidden" name="userName" value="<%= pet.userName %>">

                <div class="appointment-grid">
                    <% 
                    const dayOptions = { weekday: 'long' };
                    const dateOptions = { month: 'short', day: 'numeric' };
                    
                    for(let i = 1; i <= 4; i++) { 
                        let d = new Date();
                        d.setDate(d.getDate() + i);
                        let dateVal = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
                    %>
                        <div class="day-column">
                            <div class="day-header">
                                <div class="day-name"><%= d.toLocaleDateString(undefined, dayOptions) %></div>
                                <div class="day-date"><%= d.toLocaleDateString(undefined, dateOptions) %></div>
                            </div>

                            <div class="time-options">
                                <% const slots = ["10:00 AM - 12:00 PM", "12:00 PM - 2:00 PM", "2:00 PM - 4:00 PM", "4:00 PM - 6:00 PM"]; %>
                                <% slots.forEach(slot => { %>
                                    <div>
                                        <input type="radio" name="appointmentDateTime" 
                                               value="<%= dateVal %>|<%= slot %>" 
                                               id="<%= dateVal %>-<%= slot %>" 
                                               class="time-slot-radio" required>
                                        <label for="<%= dateVal %>-<%= slot %>" class="time-slot-label">
                                            <%= slot %>
                                        </label>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <button type="submit">Confirm Appointment</button>
            </form>
        <% } else { %> <p>No pet data found for this adoption request.</p>
        <% } %> </div>
</body>
</html>