<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add User Record</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- CSS to beautify page -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-image: url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: #fff;
            padding: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 30px 25px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            margin-top: 20px;
        }

        h3 {
            text-align: center;
            margin-bottom: 20px;
            font-weight: 600;
        }

        label {
            font-size: 0.85rem;
            opacity: 0.85;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            margin-bottom: 15px;
            border: none;
            border-radius: 8px;
            background: rgba(255,255,255,0.15);
            color: white;
            outline: none;
        }

        input::placeholder {
            color: rgba(255,255,255,0.6);
        }

        .radio-group {
            display: flex;
            gap: 15px;
            margin-top: 5px;
            margin-bottom: 15px;
            font-size: 0.85rem;
        }

        .radio-group input {
            width: auto;
        }

        button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff9800, #ffb74d);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        }

        .msg {
            text-align: center;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .error {
            color: #ff6b6b;
        }

        .success {
            color: #90ee90;
        }
    </style>
</head>

<body>
    <%- include("common/header") %>

    <div class="card">
        <h3>Add User Record</h3>

        <!-- Displays error message -->
        <% if (!result || result==="fail") { %>
            <p class="msg error"><%= msg %></p>
        <% } %>

        <!-- Displays success message -->
        <% if (result && result !== "fail") { %>
            <p class="msg success">User added successfully!</p>
        <% } %>
        
        <form action="/add-user" method="POST">
            <!-- Username -->
            <label for="userName">Username</label>
            <input type="text" name="userName" value="<%= userName || '' %>" required>

            <!-- Full Name -->
            <label for="fullName">Full Name</label>
            <input type="text" name="fullName" value="<%= fullName || '' %>" required>

            <!-- Password -->
            <label for="password">Password</label>
            <input type="password" name="password" required>

            <!-- Confirm Password -->
            <label for="password2">Confirm Password</label>
            <input type="password" name="password2" required>

            <!-- Gender -->
            <label>Gender</label>
            <div class="radio-group">
                <label><input type="radio" name="gender" value="Male"> Male</label>
                <label><input type="radio" name="gender" value="Female" checked> Female</label>
            </div>

            <!-- Type -->
            <label>Type</label>
            <select name="type">
                <option value="user">User</option>
                <option value="admin">Admin</option>
            </select>

            <button type="submit">Add User</button>
        </form>
    </div>
</body>
</html>