<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Appointments</title>
    <link rel="icon" type="image/x-icon" href="/img/paw.png">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url("./img/bg2.png");
            background-size: cover;
            background-position: center;
            color: white;
            padding: 20px;
        }

        .container {
            padding: 20px;
        }

        h1 {
            margin-bottom: 15px;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            overflow: hidden;
            margin-top: 10px;
        }

        th, td {
            padding: 12px 14px;
            text-align: left;
        }

        th {
            background: rgba(255, 183, 0, 0.15);
            font-weight: 500;
        }

        tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        tr:hover {
            background: rgba(255,255,255,0.05);
        }

        .action-btn {
            padding: 5px 10px;
            border-radius: 20px;
            background: rgba(255, 183, 77, 0.2);
            border: 1px solid rgba(255, 183, 77, 0.6);
            color: #ffcc80;
            text-decoration: none;
            font-size: 0.75rem;
            margin-right: 5px;
            transition: all 0.2s ease;
        }

        .action-btn:hover {
            background: rgba(255, 183, 77, 0.35);
            color: #fff;
        }

        .action-btn.danger {
            border-color: rgba(255, 77, 77, 0.6);
            background: rgba(255, 77, 77, 0.2);
            color: #ff9a9a;
        }

        .action-btn.danger:hover {
            background: rgba(255, 77, 77, 0.35);
            color: #fff;
        }

        .back-link {
            display: inline-block;
            margin-top: 15px;
            color: #ffcc80;
            text-decoration: none;
        }

        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>
    <%- include("common/header") %>

    <div class="container">
        <h1>My Appointments</h1>
        
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Pet ID</th>
                    <th>Pet Name</th> 
                    <th>Date</th>
                    <th>Time</th>
                    <th>Change Appointment</th>
                </tr>
            </thead>
            <tbody>
                <% if (appointments.length > 0) { %>
                    <% appointments.forEach(app => { %>
                            <tr>
                                <td><%= app.userName %></td>
                                <td><%= app.petId %></td>
                                <td><%= app.name %></td>
                                <td><%= app.date %></td>
                                <td><%= app.time %></td>
                                <td>
                                    <!-- One click: This stops the click for a second and asks the user "Are you sure?". if they click "No", the "baton" is dropped and nothing happens. -->
                                    <a href="/edit-appointment/<%= app._id %>" class="action-btn">Reschedule</a>

                                    <a href="/delete-appointment/<%= app._id %>" 
                                        onclick="return confirm('Are you sure you want to cancel this booking?')" 
                                        class="action-btn danger">
                                        Cancel
                                    </a>
                                </td>
                            </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="3" style="text-align:center;">No appointments found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <br>
        <a href="/display-pet" class="back-link action-btn">Go Back Home</a>
    </div>
</body>
</html>