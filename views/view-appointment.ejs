<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Appointments</title>
    <link rel="icon" type="image/x-icon" href="/img/paw.png">
    
    <style>
        body {
            /* Fix: Changed ./img to /img and added a dark fallback color */
            background: #2c3e50 url("/img/bg2.png") no-repeat center center fixed; 
            background-size: cover;
            color: white;
            font-family: Arial, sans-serif;
        }

        table {
            border-collapse: collapse;
            width: 80%;
            margin-top: 20px;
            background-color: rgba(0, 0, 0, 0.6); /* Makes table readable against image */
        }

        th, td {
            border: 1px solid white;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .container {
            padding: 20px;
        }
    </style>
</head>

<body>
    <%- include("common/header") %>

    <div class="container">
        <h1>My Appointments</h1>
        
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Pet ID</th>
                    <th>Pet Name</th> <!-- added name column -->
                    <th>Date</th>
                    <th>Time</th>
                    <th>Change Appointment</th>
                </tr>
            </thead>
            <tbody>
                <% if (appointments.length > 0) { %>
                    <% appointments.forEach(app => { %>
                            <tr>
                                <td><%= app.userName %></td>
                                <td><%= app.petId %></td>
                                <td><%= app.name %></td>
                                <td><%= app.date %></td>
                                <td><%= app.time %></td>
                                <!-- reschedule button -->
                                <td>
                                    <a href="/edit-appointment/<%= app._id %>" style="color: #ffcc00;">Reschedule</a>
                                </td>
                                <!-- One click: This stops the click for a second and asks the user "Are you sure?". if they click "No", the "baton" is dropped and nothing happens. -->
                                <!-- Cancel button -->
                                <td>
                                <a href="/delete-appointment/<%= app._id %>" 
                                    onclick="return confirm('Are you sure you want to cancel this booking?')" 
                                    style="color: red;">
                                    Cancel
                                </a>
                                </td>
                            </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="3" style="text-align:center;">No appointments found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <br>
        <a href="/" style="color: #ffcc00;">Go Back Home</a>
    </div>
</body>
</html>