<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Pet Record</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
</head>

<style>
    body {
        background-image: url("./img/bg2.png");
        background-attachment: fixed;  
        background-size: cover;
        color: white;
    }
</style>

<body>
    <%- include("common/header") %>

    <h3>Delete Pet Record</h3>
    
    <!-- Displays error message -->
    <% if (!result || result==="fail") { %>
        <p style="color: red;"><%= msg %></p>
    <% } else if (result) { %> 

    <!-- Displays success message -->

        <p style="color: lightgreen;">Pet deleted successfully!</p>
    <% } %>
    
    <form action="/del-pet" method="POST">
        <!-- PetID -->
        <label for="recordID">Record ID:</label><br>
        <input type="text" ID="recordID" name="recordID" required placeholder="What's this record ID?">

        <br><br>

        <button type="submit">Delete Pet!</button>       
    </form>
</body>
</html>