<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Pet Records</title>
    <link rel="icon" type="image/x-icon" href="./img/paw.png">
</head>

<style>
    body {
        background-image: url("./img/bg2.png");
        background-attachment: fixed;  
        background-size: cover;
        color: white;
    }
    table {
        border-collapse: collapse;
    }
    th, td {
        padding: 10px 15px;
        text-align: left;
    }
</style>
<body>
     
   <%- include("common/header") %>

    <h3>Edit Pet Record</h3>
    
    <form action="/update-pet" method="GET">
    
        <label>Select Pet:</label><br>

        <select name="id" required>
          <option value="">-- Choose a pet --</option>

          <% petList.forEach(pet => { %>
            <option value="<%= pet.id %>">
              <%= pet.name %> (ID: <%= pet.id %>)
            </option>
          <% }); %>

        </select>

        <br><br>

        <button type="submit">Edit Pet!</button>       
    </form>
</body>
</html>
